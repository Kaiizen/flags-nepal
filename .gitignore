# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Next.js — ignore everything under .next except the self-contained standalone bundle produced by
# `npm run build:cpanel` (includes public/, traced node_modules, .next/static, .next/server inside it).
.next/*
!.next/standalone/
!.next/standalone/**

/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# image watermark backup — pre-watermark originals snapshot created by
# `scripts/watermark-images.mjs`. Large and reproducible from source.
/.image-originals-backup

# Lighthouse CLI output (`npx lighthouse ... --output-path=./lighthouse-home`)
/lighthouse-home.report.html
/lighthouse-home.report.json
/lighthouse-home-desktop.report.html
/lighthouse-home-desktop.report.json
/lighthouse-home-mobile-after.report.json
/lighthouse-home-mobile-final.report.json
/lighthouse-m-*.json
/lighthouse-home-mobile-r2
# Ad-hoc Lighthouse dumps (hostname in filename)
/127.0.0.1_*.report.html

# typescript
*.tsbuildinfo
next-env.d.ts
