# Public site URL (production)
NEXT_PUBLIC_SITE_URL=https://flagsnepal.com

# Optional — Google Maps embed src for /contact (only set if Google gives you a new embed)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

# Google Places API — required to show real Google reviews in the homepage Testimonials section.
# 1) Create a key in Google Cloud Console.
# 2) Enable "Places API".
# 3) Put the key here.
GOOGLE_MAPS_API_KEY=

# Optional but recommended — avoids a lookup call and makes reviews deterministic.
# Find it at: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# --- Resend (contact form email delivery) ---
#
# 1. Sign up at https://resend.com and create an API key (Dashboard → API Keys).
# 2. For production, verify your domain (Dashboard → Domains → Add flagsnepal.com
#    and add the DNS records Resend shows you). Until verified, you can only send
#    from the sandbox address `onboarding@resend.dev` and only to the account owner.
# 3. Put the real values in `.env` (gitignored), not in this file.
RESEND_API_KEY=

# From address used on outgoing contact-form emails.
# - If unset, falls back to Resend's sandbox sender "Flags Nepal <onboarding@resend.dev>".
# - For production use, set this to a verified domain address, e.g.
#   RESEND_FROM_EMAIL="Flags Nepal <hello@flagsnepal.com>"
RESEND_FROM_EMAIL=

# Inbox that receives contact-form submissions.
# - Defaults to flagsnepal@gmail.com (from siteConfig.email) when unset.
# - Set this to override (e.g. route to a team alias or shared inbox).
CONTACT_INBOX_EMAIL=
