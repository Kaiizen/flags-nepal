e:T1391,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Where can I buy an official Nepal flag in Kathmandu?","acceptedAnswer":{"@type":"Answer","text":"You can order national, ceremonial, and custom-printed Nepal flags from Flags Nepal in Bagbazar, Kathmandu — in person, by phone, WhatsApp, or through the contact form. We supply desk stands, floor stands, hand flags, and large-format flags with proportion-correct geometry. If you need exact legal proportions for an institutional hoisting, ask for a proof that follows Schedule 3 of the Constitution of Nepal before we print."}},{"@type":"Question","name":"Do you deliver across all provinces in Nepal?","acceptedAnswer":{"@type":"Answer","text":"Yes. We coordinate courier and transport delivery across all seven provinces. Lead times depend on your location, order size, and material availability. For urgent national-day or event deadlines, contact us early so we can slot production and choose the fastest safe shipping option."}},{"@type":"Question","name":"What is the difference between a table stand and a floor (golden) stand?","acceptedAnswer":{"@type":"Answer","text":"Table stands are compact displays for reception desks, podiums, and meeting rooms, usually with smaller flag formats. Floor stands (including our golden stand series) are taller ceremonial systems for offices, foyers, and formal spaces, often with larger flags. If you are unsure, tell us the room size and viewing distance and we will recommend a stand and flag size."}},{"@type":"Question","name":"What currency are your prices in and can they change?","acceptedAnswer":{"@type":"Answer","text":"All prices are quoted in Nepalese Rupees (NPR) and are subject to change without prior notice. The final price is based on the selected fabric, size, quantity, and printing specifications. Listed catalogue prices are inclusive of VAT; conditions apply."}},{"@type":"Question","name":"What payment methods do you accept and how does payment work?","acceptedAnswer":{"@type":"Answer","text":"Online orders are confirmed with 50% advance payment, and the remaining 50% is paid on delivery (COD). Bulk or institutional orders follow custom payment terms — please contact us to arrange them. We accept cash, bank transfer, and digital wallets including eSewa and Khalti."}},{"@type":"Question","name":"Can I order custom sizes and designs?","acceptedAnswer":{"@type":"Answer","text":"Yes. Custom sizes, designs, and specifications are produced as per the customer's written approval. Customers are responsible for providing accurate artwork, dimensions, and colour references."}},{"@type":"Question","name":"Can I change or cancel an order after approving a proof?","acceptedAnswer":{"@type":"Answer","text":"Once a design proof or sample is approved by the customer, no changes or cancellations will be accepted. Please review proofs carefully before approval."}},{"@type":"Question","name":"How long does production and delivery take?","acceptedAnswer":{"@type":"Answer","text":"Standard production time varies depending on order size and material availability. Delivery timelines are estimates and may be affected by weather, transport delays, or material shortages. Urgent orders may incur additional express service charges."}},{"@type":"Question","name":"Will there be slight colour or size variations?","acceptedAnswer":{"@type":"Answer","text":"Minor colour or size variations may occur due to printing and fabric characteristics. These are not considered defects. If a product is found to be faulty, it must be reported within 48 hours of delivery."}},{"@type":"Question","name":"What is your return and refund policy?","acceptedAnswer":{"@type":"Answer","text":"Returns are accepted only for manufacturing defects and must be approved by our management. Custom-printed products cannot be refunded or exchanged unless defective. Approved refunds are processed within 7–10 working days."}},{"@type":"Question","name":"Who is responsible for artwork and copyright?","acceptedAnswer":{"@type":"Answer","text":"All logos, images, and artwork provided by the customer are assumed to be legally owned or licensed for use. Flags Nepal is not responsible for copyright infringements arising from customer-supplied designs."}},{"@type":"Question","name":"What is Flags Nepal's liability for delays or losses?","acceptedAnswer":{"@type":"Answer","text":"Our liability is limited to the value of the product sold. We are not responsible for indirect losses such as missed events, reprinting costs, or loss of business caused by product delays or errors."}},{"@type":"Question","name":"How do I place an order?","acceptedAnswer":{"@type":"Answer","text":"Use the contact form with your specifications, email info@flagsnepal.com, or call our studio line. A production coordinator will confirm materials, timeline, and pricing before we move to deposit and scheduling. By placing an order, the customer agrees to our Terms and Conditions."}}]}2:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$e"}}],["$","$Lf",null,{}],[["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[88px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/TrustRow"]}],"$L12"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[180px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/ClientLogos"]}],"$L13"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[420px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/Works"]}],"$L14"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[640px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/Process"]}],"$L15"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[520px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/Services"]}],"$L16"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[300px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/Testimonials"]}],"$L17"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[380px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/ExploreResources"]}],"$L18"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[480px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/FAQ"]}],"$L19"]}],["$","$10",null,{"fallback":["$","div",null,{"className":"w-full min-h-[160px]","aria-hidden":true,"role":"presentation"}],"children":[["$","$L11",null,{"moduleIds":["components/home/HomeDeferredSections.tsx -> @/components/sections/ClosingCTA"]}],"$L1a"]}]]]
