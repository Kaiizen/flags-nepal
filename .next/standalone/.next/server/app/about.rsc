:"City","name":"Kathmandu"},{"@type":"AdministrativeArea","name":"Bagmati Province"},{"@type":"Country","name":"Nepal"}],"sameAs":["https://www.facebook.com/flagsNepaI/","https://instagram.com/flagsnepal","https://www.tiktok.com/@flagsnepal","https://www.youtube.com/@FlagsNepal","https://www.linkedin.com/company/flags-nepal"],"openingHoursSpecification":{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"09:00","closes":"18:00"},"knowsAbout":["Nepal national flag","Custom flag printing Nepal","Ceremonial flags and stands","Table flag stands","Beach and outdoor banner systems","Sublimation and foil printing"]}]}0:["VCOiBouMs4NC9JDXRQbv1",[[["",{"children":["about",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["about",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"page-shell-dark relative overflow-hidden","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://flagsnepal.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"About\",\"item\":\"https://flagsnepal.com/about\"}]}"}}],["$","div",null,{"className":"page-container relative z-10","children":[["$","$L2",null,{"initialY":16,"children":[["$","p",null,{"lang":"ne","className":"mb-4 text-gold/70 font-nepali text-[14px] font-medium leading-relaxed tracking-[0em] normal-case antialiased md:text-[16px] [text-rendering:optimizeLegibility]","children":"हाम्रो कथा"}],["$","h1",null,{"className":"font-display font-bold leading-[1.14] tracking-[-0.03em] text-cream","children":[["$","span",null,{"className":"block text-[clamp(2.4rem,7vw,4.2rem)]","children":"STUDIO"}],["$","span",null,{"className":"block text-[clamp(2.4rem,7vw,4.2rem)]","children":["$","em",null,{"className":"font-normal not-italic hero-pride","children":"Origin"}]}]]}]]}],["$","$L2",null,{"className":"mt-14 block","initialY":28,"children":["$","div",null,{"className":"grid gap-12 md:grid-cols-[1.1fr_0.9fr]","children":[["$","div",null,{"className":"space-y-6 text-[14px] leading-[1.9] text-cream/40","children":[["$","p",null,{"children":"Flags Nepal was founded in 2018 in Bagbazar, Kathmandu — a small workshop started by printers and stitchers who cared deeply about getting the national flag right. Our first orders were humble: replacement flags for neighbourhood schools, pennants for local clubs, and hand-stitched table sets for offices across the valley."}],["$","p",null,{"children":"Eight years on, we are still a Nepali workshop at heart. We print and stitch for schools and community campuses, municipal offices, sports clubs, cricket and football fan groups, trekking agencies, event organisers, temples, and family-run businesses from Kathmandu to Pokhara, Biratnagar, Butwal, Dharan, and beyond. When a team needs jerseys for a tournament, a school needs a flag for Constitution Day, or a brand needs banners for a product launch in the valley — we are usually the first call."}],["$","p",null,{"children":"The constitution sets exact geometry for our national flag, and that respect for detail sets the standard for every job that leaves the workshop. We cut patterns by hand when the shape demands it, match Pantone references under daylight-balanced lamps, and reinforce hems so a flag survives monsoon winds and dry Kathmandu sun. Rollers, needles, and heat presses make a lot of noise; the work itself is quiet discipline — measure twice, print once, hoist forever."}],["$","p",null,{"children":"From Bagbazar we coordinate deliveries across all seven provinces, with courier partners handling orders from Jhapa to Darchula. Walk-ins are welcome for anyone nearby — we will happily talk through fabric, size, and finishing over a cup of tea before quoting a price."}],["$","p",null,{"children":["For constitutional geometry and format guidance, visit our"," ",["$","a",null,{"href":"/nepal-flag-proportions","className":"text-gold/80 underline-offset-2 hover:underline","children":"Nepal flag proportions guide"}],"."]}]]}],["$","div",null,{"className":"relative overflow-hidden rounded-sm border border-cream/[0.06] bg-cream/[0.03] p-8","children":[["$","$L3",null,{"src":"/flags-nepal-logo-white.png","alt":"","width":240,"height":240,"className":"absolute left-1/2 top-1/2 h-auto w-[min(130px,30%)] -translate-x-1/2 -translate-y-1/2 opacity-[0.04]","aria-hidden":true}],["$","div",null,{"className":"relative z-10 space-y-4","children":[["$","p",null,{"lang":"ne","className":"text-gold/70 font-nepali text-[14px] font-medium leading-relaxed tracking-[0em] normal-case antialiased md:text-[16px] [text-rendering:optimizeLegibility]","children":"एक नजरमा"}],["$","ul",null,{"className":"space-y-3 text-[14px] text-cream/40","children":[["$","li",null,{"children":[["$","span",null,{"className":"font-medium text-cream","children":"Founded:"}]," 2018, Bagbazar, Kathmandu"]}],["$","li",null,{"children":[["$","span",null,{"className":"font-medium text-cream","children":"Focus:"}]," Flags, banners, jerseys, foil, desk systems"]}],["$","li",null,{"children":[["$","span",null,{"className":"font-medium text-cream","children":"Serves:"}]," Schools, clubs, municipalities, brands, and families across Nepal"]}],["$","li",null,{"children":[["$","span",null,{"className":"font-medium text-cream","children":"Principles:"}]," Constitutional accuracy, reinforced hems, honest timelines"]}]]}]]}]]}]]}]}]]}]]}],null],null],null]},[null,["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","about","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/